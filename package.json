{
  "name": "agent-garrison",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Local-first composer and runner for autonomous agent setups.",
  "scripts": {
    "start": "bash scripts/garrison-instance.sh dev start",
    "dev": "bash scripts/garrison-instance.sh dev start",
    "dev:next": "bash scripts/garrison-instance.sh dev next",
    "start:mobile": "bash scripts/garrison-instance.sh dev mobile",
    "build": "next build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "npm test && npm run test:e2e",
    "check:integration": "node scripts/integration-check.mjs",
    "refresh:prompts": "tsx scripts/refresh-default-prompts.ts",
    "refresh:settings-schema": "tsx scripts/refresh-settings-schema.ts",
    "import:claude": "tsx scripts/import-claude-install.ts",
    "config": "tsx scripts/garrison-config.ts",
    "test:integration": "GARRISON_INTEGRATION=1 vitest run tests/orchestrator-integration.test.ts",
    "test:pty": "GARRISON_INTEGRATION=1 vitest run tests/gateway-pty.integration.test.ts",
    "kanban:v1d:walkthrough": "node scripts/kanban-v1d-walkthrough.mjs",
    "postinstall": "node scripts/fix-node-pty-permissions.mjs",
    "prod:build": "bash scripts/garrison-instance.sh prod build",
    "prod:start": "bash scripts/garrison-instance.sh prod start",
    "prod:redeploy": "bash scripts/garrison-redeploy.sh",
    "codex:start": "bash scripts/garrison-instance.sh codex start"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@garrison/claude-chat": "file:packages/claude-chat",
    "@garrison/claude-pty": "file:packages/claude-pty",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@ricky0123/vad-web": "^0.0.30",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^3.6.0",
    "clsx": "^2.1.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.468.0",
    "marked": "^14.0.0",
    "next": "^14.2.35",
    "node-pty": "^1.1.0",
    "onnxruntime-web": "^1.26.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "smol-toml": "^1.7.0",
    "systeminformation": "^5.31.15",
    "three": "^0.176.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.185.0",
    "@types/ws": "^8.5.13",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.0",
    "fast-check": "^4.9.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
