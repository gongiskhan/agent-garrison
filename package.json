{
  "name": "agent-garrison",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first composer and runner for autonomous agent setups.",
  "scripts": {
    "start": "concurrently --names next,outpost \"next dev -H 127.0.0.1 -p 7777\" \"node scripts/outpost-host.mjs\"",
    "dev": "concurrently --names next,outpost \"next dev -H 127.0.0.1 -p 7777\" \"node scripts/outpost-host.mjs\"",
    "dev:next": "next dev -H 127.0.0.1 -p 7777",
    "start:mobile": "concurrently --names next,outpost \"next dev -H 0.0.0.0 -p 7777\" \"node scripts/outpost-host.mjs\"",
    "build": "next build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "npm test && npm run test:e2e",
    "check:integration": "node scripts/integration-check.mjs",
    "refresh:prompts": "tsx scripts/refresh-default-prompts.ts",
    "refresh:settings-schema": "tsx scripts/refresh-settings-schema.ts",
    "import:claude": "tsx scripts/import-claude-install.ts",
    "test:integration": "GARRISON_INTEGRATION=1 vitest run tests/orchestrator-integration.test.ts",
    "test:pty": "GARRISON_INTEGRATION=1 vitest run tests/gateway-pty.integration.test.ts",
    "kanban:v1d:walkthrough": "node scripts/kanban-v1d-walkthrough.mjs",
    "postinstall": "node scripts/fix-node-pty-permissions.mjs"
  },
  "dependencies": {
    "@garrison/claude-chat": "file:packages/claude-chat",
    "@garrison/claude-pty": "file:packages/claude-pty",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^3.6.0",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.468.0",
    "marked": "^14.0.0",
    "next": "^14.2.35",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
