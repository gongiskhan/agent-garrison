    }
  },
  "workKinds": {
    "docs-change": { "phasePlan": "implement-only-text", "description": "Documentation or prose-only change" },
    "api-change": { "phasePlan": "implement-test", "description": "API/backend change with tests, no walkthrough" },
    "video-edit": { "phasePlan": "implement-only-logs", "description": "Video production/edit work" },
    "ui-change": { "phasePlan": "ui-change", "description": "UI change through review + UX QA + a walkthrough" },
    "full-feature": { "phasePlan": "full", "description": "Feature work through the full gated pipeline" }
