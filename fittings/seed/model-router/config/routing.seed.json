{
  "version": 1,
  "activeProfile": "balanced",
  "roles": ["expert", "standard", "fast", "image", "video", "review"],
  "taskTypes": ["code", "review", "research", "image", "video", "writing", "ops", "other"],
  "tiers": ["T0-trivial", "T1-standard", "T2-deep"],
  "tierDefinitions": {
    "T0-trivial": "A one-shot answer or a single mechanical edit: a rename, a typo, a fact lookup, a one-line config tweak. No multi-file reasoning, no design choices.",
    "T1-standard": "Ordinary day-to-day work: a bounded feature, a localized bug fix, a focused refactor, a normal review. Some reasoning across a few files; outcome is checkable by a test.",
    "T2-deep": "High-stakes or wide-blast-radius work: architecture, a tricky bug with unclear cause, a security-sensitive change, a multi-subsystem migration. Warrants the strongest model, full gates, and recorded evidence."
  },
  "exceptions": [
    { "id": "ex-secrets", "when": "the prompt involves secrets, credentials, auth tokens, or the vault", "role": "review" },
    { "id": "ex-image", "when": "the prompt asks to generate, edit, or analyze an image", "role": "image" },
    { "id": "ex-video", "when": "the prompt asks to generate or edit a video", "role": "video" }
  ],
  "matrix": {
    "defaults": { "role": "standard" },
    "columns": { "T2-deep": "expert" },
    "rows": {
      "code": { "default": "standard", "cells": { "T0-trivial": "fast", "T2-deep": "expert" } },
      "review": { "default": "review", "cells": { "T0-trivial": "fast" } },
      "research": { "default": "standard", "cells": { "T2-deep": "expert" } },
      "image": { "default": "image", "cells": {} },
      "video": { "default": "video", "cells": {} },
      "writing": { "default": "standard", "cells": { "T0-trivial": "fast" } },
      "ops": { "default": "standard", "cells": { "T0-trivial": "fast" } },
      "other": { "default": "standard", "cells": { "T0-trivial": "fast" } }
    }
  },
  "discipline": {
    "T0-trivial": { "review": "none", "testing": "none", "evidence": "none", "distribution": "none" },
    "T1-standard": { "review": "self-review", "testing": "tests", "evidence": "text", "distribution": "none" },
    "T2-deep": { "review": "review-by:default", "testing": "full-gates", "evidence": "video", "distribution": "link" }
  },
  "continuations": [
    {
      "id": "cont-plan",
      "when": "plan",
      "then": [
        { "verb": "ask", "arg": "Implement this plan?" },
        { "verb": "route", "arg": "cc-sonnet-med" }
      ]
    },
    {
      "id": "cont-report",
      "when": "report",
      "then": [
        { "verb": "store" },
        { "verb": "ask", "arg": "Act on this report?" }
      ]
    }
  ],
  "targets": [
    { "id": "cc-opus-high", "type": "runtime-target", "runtime": "claude-code", "provider": "anthropic-plan", "model": "opus", "effort": "high" },
    { "id": "cc-sonnet-med", "type": "runtime-target", "runtime": "claude-code", "provider": "anthropic-plan", "model": "sonnet", "effort": "medium" },
    { "id": "cc-haiku-low", "type": "runtime-target", "runtime": "claude-code", "provider": "anthropic-plan", "model": "haiku", "effort": "low" },
    { "id": "cc-ollama-qwen", "type": "runtime-target", "runtime": "claude-code", "provider": "ollama-local", "model": "qwen2.5-coder", "effort": "medium" },
    { "id": "cc-ollama-deepseek", "type": "runtime-target", "runtime": "claude-code", "provider": "ollama-local", "model": "deepseek-coder-v2", "effort": "medium" },
    { "id": "sec-gemini", "type": "secondary", "runtime": "gemini" },
    { "id": "sec-codex", "type": "secondary", "runtime": "codex" },
    { "id": "classifier", "type": "runtime-target", "runtime": "claude-code", "provider": "anthropic-plan", "model": "haiku", "effort": "low", "pinned": true }
  ],
  "profiles": {
    "balanced": {
      "preRoute": "on",
      "roleMap": {
        "expert": "cc-opus-high",
        "standard": "cc-sonnet-med",
        "fast": "cc-haiku-low",
        "image": "sec-gemini",
        "video": "sec-gemini",
        "review": "cc-sonnet-med"
      },
      "disciplineOverrides": {}
    },
    "economy": {
      "preRoute": "on",
      "roleMap": {
        "expert": "cc-ollama-qwen",
        "standard": "cc-ollama-qwen",
        "fast": "cc-haiku-low",
        "image": "sec-gemini",
        "video": "sec-gemini",
        "review": "cc-haiku-low"
      },
      "disciplineOverrides": {
        "T2-deep": { "review": "self-review", "testing": "tests", "evidence": "text", "distribution": "none" }
      }
    },
    "premium": {
      "preRoute": "on",
      "roleMap": {
        "expert": "cc-opus-high",
        "standard": "cc-opus-high",
        "fast": "cc-sonnet-med",
        "image": "sec-gemini",
        "video": "sec-gemini",
        "review": "cc-opus-high"
      },
      "disciplineOverrides": {}
    }
  }
}
