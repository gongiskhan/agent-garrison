+.hljs-number { color: var(--cc-tok-num); }
+.hljs-attr, .hljs-attribute, .hljs-name, .hljs-tag, .hljs-selector-tag, .hljs-symbol { color: var(--cc-tok-attr); }
+.hljs-addition { color: #7ee787; }
+.hljs-deletion { color: #ff7b72; }
+
+/* ── Per-message actions (copy / read-aloud) ── */
+.cc-msgactions { margin-top: 6px; display: inline-flex; align-items: center; gap: 6px; opacity: 0.55; transition: opacity 0.12s; }
+.cc-assistant:hover .cc-msgactions, .cc-msgactions:focus-within { opacity: 1; }
+.cc-msgcopy {
+  font-size: 11px; background: transparent; border: 1px solid var(--cc-border-strong); color: var(--cc-fg-dim);
+  border-radius: 5px; padding: 2px 9px; cursor: pointer;
+}
+.cc-msgcopy:hover { color: var(--cc-fg); border-color: var(--cc-accent); }
