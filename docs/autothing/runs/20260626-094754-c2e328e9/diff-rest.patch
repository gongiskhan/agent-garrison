+/* ── Streaming cursor (shown once tokens arrive) ── */
+.cc-cursor {
+  display: inline-block; width: 7px; height: 1.05em; vertical-align: text-bottom; margin-left: 1px;
+  background: var(--cc-accent); animation: cc-blink 1s steps(1) infinite;
+}
+@keyframes cc-blink { 50% { opacity: 0; } }
+
+/* ── Working / thinking indicator (before the first token) ── */
+.cc-working {
+  display: inline-flex; align-items: center; gap: 9px; margin-top: 2px;
+  padding: 6px 11px; border: 1px solid var(--cc-border); background: var(--cc-bg-elev); border-radius: 8px;
+}
+.cc-working-dots { display: inline-flex; gap: 4px; }
+.cc-working-dots i {
+  width: 5px; height: 5px; border-radius: 50%; background: var(--cc-accent); display: inline-block;
+  animation: cc-bounce 1.2s infinite ease-in-out;
+}
+.cc-working-dots i:nth-child(2) { animation-delay: 0.15s; }
+.cc-working-dots i:nth-child(3) { animation-delay: 0.3s; }
+@keyframes cc-bounce { 0%, 80%, 100% { transform: translateY(0); opacity: 0.4; } 40% { transform: translateY(-4px); opacity: 1; } }
+.cc-working-label { font-size: 11px; color: var(--cc-fg-dim); letter-spacing: 0.04em; }
+.cc-working-time { font-size: 11px; color: var(--cc-fg-faint); font-variant-numeric: tabular-nums; }
+.cc-working-hint {
+  font: 11px ui-monospace, SFMono-Regular, Menlo, monospace; color: var(--cc-fg-faint);
+  max-width: 240px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
+}
+
+/* ── Rich code block (custom marked renderer): header + highlighted body ── */
+.cc-codeblock { margin: 0 0 10px; border: 1px solid var(--cc-code-border); border-radius: 8px; overflow: hidden; }
+.cc-codehead {
+  display: flex; align-items: center; justify-content: space-between; gap: 8px;
+  background: var(--cc-bg-elev); border-bottom: 1px solid var(--cc-code-border); padding: 5px 10px;
+}
+.cc-codelang { font: 10px ui-monospace, SFMono-Regular, Menlo, monospace; letter-spacing: 0.08em; text-transform: uppercase; color: var(--cc-fg-dim); }
+.cc-codecopy {
+  font-size: 10px; letter-spacing: 0.04em; background: transparent; border: 1px solid var(--cc-border-strong);
+  color: var(--cc-fg-dim); border-radius: 5px; padding: 2px 8px; cursor: pointer;
+}
+.cc-codecopy:hover { color: var(--cc-fg); border-color: var(--cc-accent); }
+.cc-codeblock pre {
+  margin: 0; border: none; border-radius: 0; background: var(--cc-code-bg);
+  padding: 10px 12px; overflow-x: auto; font: 12px/1.45 ui-monospace, SFMono-Regular, Menlo, monospace;
+}
+.cc-codeblock pre code { background: none; padding: 0; color: var(--cc-fg); }
+
+/* hljs token palette — theme-driven CSS vars so it reads on the dark code card
+   (base + web-channel + dev-env dark) and the light one (dev-env light). */
+.cc-root {
+  --cc-tok-kw: #ff7b72; --cc-tok-str: #a5d6ff; --cc-tok-com: #8b949e;
+  --cc-tok-fn: #d2a8ff; --cc-tok-num: #79c0ff; --cc-tok-attr: #7ee787;
+}
+.cc-root[data-theme="light"] {
+  --cc-tok-kw: #a3303d; --cc-tok-str: #2f6347; --cc-tok-com: #7d8077;
+  --cc-tok-fn: #6b4d9a; --cc-tok-num: #2f5d86; --cc-tok-attr: #2f6347;
+}
+.hljs-keyword, .hljs-built_in, .hljs-type, .hljs-literal { color: var(--cc-tok-kw); }
+.hljs-string, .hljs-meta .hljs-string, .hljs-regexp { color: var(--cc-tok-str); }
+.hljs-comment, .hljs-quote { color: var(--cc-tok-com); font-style: italic; }
+.hljs-title, .hljs-title.function_, .hljs-section { color: var(--cc-tok-fn); }
+.hljs-number { color: var(--cc-tok-num); }
+.hljs-attr, .hljs-attribute, .hljs-name, .hljs-tag, .hljs-selector-tag, .hljs-symbol { color: var(--cc-tok-attr); }
+.hljs-addition { color: #7ee787; }
+.hljs-deletion { color: #ff7b72; }
+
+/* ── Per-message actions (copy / read-aloud) ── */
+.cc-msgactions { margin-top: 6px; display: inline-flex; align-items: center; gap: 6px; opacity: 0.55; transition: opacity 0.12s; }
+.cc-assistant:hover .cc-msgactions, .cc-msgactions:focus-within { opacity: 1; }
+.cc-msgcopy {
+  font-size: 11px; background: transparent; border: 1px solid var(--cc-border-strong); color: var(--cc-fg-dim);
+  border-radius: 5px; padding: 2px 9px; cursor: pointer;
+}
+.cc-msgcopy:hover { color: var(--cc-fg); border-color: var(--cc-accent); }
+
 /* Per-message read-aloud button (appears under a completed assistant turn). */
