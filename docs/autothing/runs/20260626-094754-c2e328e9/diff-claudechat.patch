+    code({ text, lang }: { text: string; lang?: string }) {
+      const language = (lang || "").trim().toLowerCase();
+      let body: string;
+      if (language && hljs.getLanguage(language)) {
+        try {
+          body = hljs.highlight(text, { language, ignoreIllegals: true }).value;
+        } catch {
+          body = escapeHtml(text);
+        }
+      } else {
+        body = escapeHtml(text);
+      }
