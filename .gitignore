node_modules/
coverage/
dist/
# Most Fitting dist/ is esbuild/vad-web BUILD OUTPUT, regenerated on station by
# `x-garrison.setup: node ui/build.mjs` (jarvis-os copies ~76MB of ort-wasm/onnx
# from node_modules) — it MUST stay ignored so it never lands in git history.
# Only these two Fittings ship a hand-authored dist/index.html with no build step;
# re-include the dir first (git can't re-include a file under an excluded dir), then the file.
!fittings/seed/automations/dist/
!fittings/seed/automations/dist/index.html
!fittings/seed/file-browser/dist/
!fittings/seed/file-browser/dist/index.html
*.log
*.tsbuildinfo
.env
.env.*
!.env.example
data/vault.json
data/vault.json.bak-*
compositions/*/.env
compositions/*/.garrison/assembled-system-prompt.md
compositions/*/.garrison/uploads/
compositions/*/.garrison/decisions.jsonl
compositions/*/.garrison/operative-session-id
compositions/*/.garrison/routing.json
compositions/*/apm_modules/
compositions/*/.claude/
compositions/*/logs/
compositions/*/data/
compositions/*/artifacts/
.idea
run-tab-fixed.png
.DS_Store
**/.DS_Store
_design-redesign/
recordings
