            {
              "type": "click",
              "selector": "article:has-text(\"Agent SDK runtime\") button.btn.small.primary"
            },
            {
              "type": "waitTimeout",
              "ms": 1500
            }
          ],
          "assert": {
            "selector": "article:has-text(\"Agent SDK runtime\")",
            "text": "Remove",
            "highlight": true
          },
          "hold": 4200
        }
      ]
    },
