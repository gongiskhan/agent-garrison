{
  "title": "Runtime routing \u2014 one Operative, many engines",
  "project": "agent-garrison",
  "folder": "runtimes-routing",
  "video": {
    "width": 1280,
    "height": 1000,
    "fps": 30
  },
  "segments": [
    {
      "type": "title",
      "id": "intro",
      "text": "One Operative, many engines",
      "subtitle": "Set up a runtime, route tasks by tier, attribute every phase \u2014 Agent Garrison",
      "reflectFlag": true,
      "duration": 3.2
    },
    {
      "type": "browser",
      "id": "dash-intro",
      "baseURL": "http://127.0.0.1:27777",
      "startPath": "/",
      "beats": [
        {
          "id": "dash-running",
          "caption": "The Garrison dashboard \u2014 the Operative is up and running.",
          "expectedScreen": "the Garrison dashboard with a composition card, a green/live 'running' status pill and a Restart Operative button",
          "actions": [
            {
              "type": "waitFor",
              "selector": ".page.dash .hero .btn.primary"
            },
            {
              "type": "waitFor",
              "selector": ".page.dash span.pill.live"
            }
          ],
          "assert": {
            "selector": ".page.dash span.pill.live",
            "text": "RUNNING",
            "highlight": true
          },
          "hold": 3600
        }
      ]
    },
    {
      "type": "browser",
      "id": "compose-station",
      "baseURL": "http://127.0.0.1:27777",
      "startPath": "/compose",
      "beats": [
        {
          "id": "search-runtimes",
          "caption": "Four runtime Fittings ship in the registry \u2014 Claude Code, Codex, Gemini, and the Agent SDK.",
          "expectedScreen": "the Compose page with a search box containing 'runtime' and result cards for the runtime fittings",
          "actions": [
            {
              "type": "waitFor",
              "selector": ".compose-search input[type=\"search\"]"
            },
            {
              "type": "fill",
              "selector": ".compose-search input[type=\"search\"]",
              "text": "runtime"
            },
            {
              "type": "waitTimeout",
              "ms": 900
            }
          ],
          "assert": {
            "selector": "text:Agent SDK runtime",
            "highlight": true
          },
          "hold": 4200
        },
        {
          "id": "runtimes-station",
          "caption": "The Runtimes station: three engines stationed \u2014 the Agent SDK runtime is not, yet.",
          "expectedScreen": "the Runtimes faculty station page with cards for claude-code, codex, gemini (selected) and Agent SDK runtime (unselected, with a + Add button)",
          "actions": [
            {
              "type": "goto",
              "path": "/compose/runtimes"
            },
            {
              "type": "waitFor",
              "selector": "article"
            },
            {
              "type": "waitTimeout",
              "ms": 600
            }
